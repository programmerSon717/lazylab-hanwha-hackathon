# 카카오 연동 환경변수 (Netlify > Site settings > Environment variables 에 등록)
# 또는 로컬: `netlify dev` 실행 시 이 값들을 .env로 복사해서 사용

# 카카오 REST API 키 (로그인 토큰 교환 + authorize client_id)
KAKAO_REST_KEY=여기에_REST_API_키

# (선택) 카카오 로그인 보안 강화용 client_secret — 카카오 콘솔에서 사용함으로 설정한 경우만
KAKAO_CLIENT_SECRET=

# 카카오페이 Admin 키 (서버-서버 결제 ready/approve)  ※ 절대 프론트엔드에 넣지 말 것
KAKAO_ADMIN_KEY=여기에_Admin_키

# 프론트(config.js)에도 REST 키를 넣어야 로그인 버튼이 실제 연동으로 동작합니다.
#   config.js > KAKAO_REST_KEY = "REST_API_키"
